# Cloud profile — copy to deploy/.env and fill in the placeholders.
#
# REQUIRED:
DOMAIN=db.example.com
EMAIL=ops@example.com

# restic backend — pick ONE form:
#   s3:s3.amazonaws.com/bucket-name
#   b2:bucket-name:path
#   sftp:user@host:/srv/restic
#   /srv/restic-local
RESTIC_REPOSITORY=s3:s3.amazonaws.com/your-bucket

# S3-compatible providers
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Backblaze B2
# B2_ACCOUNT_ID=
# B2_ACCOUNT_KEY=

AGENTCOOPDB_LOG_FORMAT=json
AGENTCOOPDB_LOG_LEVEL=info
